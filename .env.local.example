# =============================================================================
# Spec-Kit — Plantilla de variables de entorno
# =============================================================================
#
# 1. Copia este archivo:  cp .env.local.example .env.local
# 2. Rellena .env.local con valores REALES (solo en tu máquina).
# 3. NUNCA subas .env.local a Git — ya está en .gitignore.
# 4. En producción usa Vercel → Settings → Environment Variables.
#
# REGLA NEXT_PUBLIC_*  → se expone al navegador (solo datos públicos).
# Sin NEXT_PUBLIC_      → solo servidor (API routes, webhooks). Mantén secreto.
# =============================================================================

# --- Públicas (cliente / navegador) ------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Debe coincidir con el puerto de `npm run dev` (3010) y con Redirect URLs en Supabase
NEXT_PUBLIC_APP_URL=http://localhost:3010

# Opcional: base URL para previews en modo demo (sin barra final)
# NEXT_PUBLIC_DEMO_PREVIEW_BASE_URL=https://demo.tu-dominio.com

# --- Secretas (solo servidor — NUNCA uses NEXT_PUBLIC_ aquí) -----------------

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Provisionar proyectos Supabase por usuario (opcional; sin esto se usa el proyecto de la plataforma)
# Token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_ORG_SLUG=
# Región para proyectos nuevos (ej. eu-west-1, us-east-1)
SUPABASE_PROVISION_REGION=eu-west-1

# Cifrado de tokens Vercel / keys Supabase en user_integrations
INTEGRATIONS_ENCRYPTION_KEY=

# OAuth GitHub (github.com/settings/developers → OAuth App)
# Callback: http://localhost:3010/api/integrations/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# OAuth Figma (figma.com/developers)
# Redirect URL: https://tu-dominio/api/integrations/figma/callback
FIGMA_OAUTH_CLIENT_ID=
FIGMA_OAUTH_CLIENT_SECRET=
# Opcional: modelo para importación Figma
# DESIGN_FIGMA_MODEL=gemini-2.5-flash

# OAuth Vercel (Integración en vercel.com/dashboard/integrations)
# Redirect URL: https://tu-dominio/api/integrations/vercel/callback
VERCEL_INTEGRATION_CLIENT_ID=
VERCEL_INTEGRATION_CLIENT_SECRET=
VERCEL_INTEGRATION_SLUG=

ANTHROPIC_API_KEY=sk-ant-your-key
DEEPSEEK_API_KEY=

# Editor IA — Vertex AI (obligatorio para IA real en local/producción)
# Sin estas variables el editor usa modo demo (mock).
# Comprueba: npm run check:vertex  y  curl http://localhost:3010/api/health
#
# Opción A: cuenta de servicio (JSON) — ruta absoluta o relativa al proyecto
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-service-account.json
# GOOGLE_CLOUD_PROJECT_ID=tu-proyecto-gcp
# GOOGLE_CLOUD_CLIENT_EMAIL=...@....iam.gserviceaccount.com
# GOOGLE_CLOUD_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_CLOUD_LOCATION=us-central1
# Opción B: JSON inline (p. ej. en Vercel)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Opción C: AI Studio — clave AIza… en https://aistudio.google.com/apikey
GEMINI_API_KEY=
# mock | gemini — con Vertex o GEMINI_API_KEY se usa gemini automáticamente
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash-lite
DESIGN_GEN_MODEL=gemini-2.5-flash

# Crédito «Trial credit for GenAI App Builder» (Facturación GCP)
# USE_GENAI_APP_BUILDER_TRIAL_CREDIT=1
# TRIAL_DESIGN_GEN_MODEL=gemini-2.5-flash-lite
# DESIGN_IMAGE_GENERATION_ENABLED=0
# IMAGE_GEN_ALLOW_API_KEY=0
# ALLOW_GEMINI_API_KEY_FALLBACK=0
# npm run check:genai-trial

# Agent Studio desplegado (NO recomendado con crédito trial — usa Vertex directo)
# DESIGN_AGENT_STUDIO_ENGINE=projects/.../reasoningEngines/...

# Chat / stream con cuenta Demo (cookie runlabs_demo). Por defecto activo; pon 0 para desactivar.
# ALLOW_DEMO_STREAM=1

STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRICE_STARTER=price_starter_pack
STRIPE_PRICE_PRO=price_pro_pack
STRIPE_PRICE_TEAM=price_team_pack

# Panel admin (emails separados por coma)
# ADMIN_EMAILS=admin@your-domain.com

# Formulario de contacto / Enterprise (Resend)
CONTACT_TO_EMAIL=you@your-domain.com
# RESEND_API_KEY=re_...
# CONTACT_FROM_EMAIL=Runlabs42 <onboarding@resend.dev>

# --- Vercel Blob (archivos de proyecto en cuenta Pro) -------------------------

BLOB_READ_WRITE_TOKEN=
# Límite de almacenamiento por usuario (MB, por defecto 100)
USER_STORAGE_LIMIT_MB=100

# Opcional: integración Stitch (Google)
# STITCH_API_KEY=
# STITCH_ACCOUNT_EMAIL=

# --- Entorno -----------------------------------------------------------------

NODE_ENV=development

# --- Vercel (automáticas en deploy; no hace falta en local) ------------------
# VERCEL=1
# VERCEL_URL=runlabs42.vercel.app
# VERCEL_ENV=production | preview | development
#
# URLs a registrar:
#   Supabase auth:  https://tu-dominio.vercel.app/auth/callback
#   Stripe webhook: https://tu-dominio.vercel.app/api/webhooks/stripe
#   Health check:   https://tu-dominio.vercel.app/api/health
