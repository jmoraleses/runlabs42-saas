{
  "name": "spec-kit-web",
  "version": "2.0.0",
  "description": "Spec-Kit Web Platform - AI-powered code generation SaaS",
  "private": true,
  "scripts": {
    "setup": "node scripts/install.mjs",
    "copy-monaco": "node scripts/copy-monaco.mjs",
    "predev": "node scripts/copy-monaco.mjs && node scripts/ensure-dev-next.mjs",
    "dev": "NODE_OPTIONS=\"${NODE_OPTIONS:-} --disable-warning=DEP0169\" next dev -p 3010",
    "dev:clean": "bash scripts/dev-clean.sh",
    "check:vertex": "node scripts/check-vertex-env.mjs",
    "check:genai-trial": "node scripts/check-genai-trial-billing.mjs",
    "deploy:design-agent": "node scripts/deploy-design-agent-studio.mjs --write-env",
    "undeploy:design-agent": "node scripts/undeploy-design-agent-gcloud.mjs",
    "probe:image-models": "node --import tsx scripts/probe-image-models.mjs",
    "probe:orchestrator": "node --import ./scripts/preload-server-only.mjs ./node_modules/tsx/dist/cli.mjs scripts/orchestrator-flash-lite-probe.mjs",
    "probe:pollitos": "node --import ./scripts/preload-server-only.mjs ./node_modules/tsx/dist/cli.mjs scripts/orchestrator-pollitos-e2e.mjs",
    "probe:ref": "node --import ./scripts/preload-server-only.mjs ./node_modules/tsx/dist/cli.mjs scripts/orchestrator-ref-image-e2e.mjs",
    "probe:consolidated": "node --import ./scripts/preload-server-only.mjs ./node_modules/tsx/dist/cli.mjs scripts/probe-consolidated-design-md.mjs",
    "probe:studio-ref": "node scripts/studio-design-generate-ref-e2e.mjs",
    "probe:studio-ref:full": "STUDIO_REF_E2E_FULL=1 node --import ./scripts/preload-server-only.mjs ./node_modules/tsx/dist/cli.mjs scripts/studio-design-generate-ref-e2e.mjs",
    "benchmark:stitch": "node --import ./scripts/preload-server-only.mjs ./node_modules/tsx/dist/cli.mjs scripts/stitch-orchestrator-benchmark.mjs",
    "stitch:sync": "node scripts/stitch-sync-reference.mjs",
    "stitch:dual": "node --import ./scripts/preload-server-only.mjs ./node_modules/tsx/dist/cli.mjs scripts/stitch-dual-generate.mjs",
    "stitch:auth": "node scripts/stitch-save-storage-state.mjs",
    "stitch:chrome-cdp": "bash scripts/stitch-chrome-cdp.sh",
    "seed:web-studio": "tsx scripts/seed-web-studio-studio.mjs",
    "seed:web-studio-local": "tsx scripts/seed-web-studio-local.mjs",
    "repair:design-heights": "tsx scripts/repair-design-page-heights.mjs",
    "prebuild": "node scripts/copy-monaco.mjs",
    "postbuild": "node -e \"require('fs').writeFileSync('.next-production-build','')\"",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "node scripts/type-check.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "db:migrate": "supabase migration up",
    "db:apply-018": "node scripts/apply-migration-018.mjs",
    "db:apply-019": "node scripts/apply-migration-019.mjs",
    "db:apply-020": "node scripts/apply-migration-020.mjs",
    "db:apply-021": "node scripts/apply-migration-021.mjs",
    "db:push": "npx supabase db push --linked --yes",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "supabase db reset",
    "analyze": "ANALYZE=true npm run build",
    "vercel": "npx vercel@latest",
    "vercel:preview": "npx vercel@latest",
    "vercel:sync-production": "bash scripts/vercel-sync-production.sh",
    "vercel:prod": "npx vercel@latest --prod",
    "vercel:env": "npx vercel@latest env pull .env.local"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^2.6.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.3.4",
    "@monaco-editor/react": "^4.6.0",
    "@octokit/oauth-app": "^8.0.3",
    "@sentry/nextjs": "^8.0.0",
    "@stripe/stripe-js": "^4.0.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.0",
    "esbuild": "^0.28.0",
    "file-type": "^22.0.1",
    "google-auth-library": "^10.6.2",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.408.0",
    "monaco-editor": "^0.52.0",
    "next": "^14.2.0",
    "next-themes": "^0.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.12.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^14.11.0",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "@sentry/cli",
      "es5-ext",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "autoprefixer": "^10.4.16",
    "dotenv": "^16.3.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "pg": "^8.13.0",
    "playwright": "^1.40.1",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
